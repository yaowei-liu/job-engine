SERPAPI_FRESHNESS_HOURS=24
SERPAPI_ALLOW_UNKNOWN_POST_DATE=false
SOURCE_FRESHNESS_HOURS=24
ALLOW_UNKNOWN_POST_DATE=false

# Quality Gate + LLM
