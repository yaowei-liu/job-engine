QUALITY_BORDERLINE_MIN=35
QUALITY_BORDERLINE_MAX=54
QUALITY_LLM_ADMIT_THRESHOLD=65
QUALITY_ALLOW_UNKNOWN_LOCATION=false
LLM_ENABLED=false
LLM_DAILY_CAP=120
LLM_MAX_PER_RUN=30
LLM_TIMEOUT_MS=15000
LLM_MODEL=gpt-4o-mini
LLM_BATCH_ENABLED=true
LLM_BATCH_THRESHOLD=20
LLM_BATCH_REALTIME_FALLBACK_COUNT=5
LLM_BATCH_MODEL=gpt-4o-mini
LLM_BATCH_POLL_INTERVAL_SEC=30
LLM_BATCH_COMPLETION_WINDOW=24h
OPENAI_API_KEY=

